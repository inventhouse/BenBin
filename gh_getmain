set -eo pipefail
# set -x  # Uncomment for debugging
DRY_RUN=echo
if [ -n "$DRY_RUN" ]; then
    echo "DRY RUN"
fi

if [ "$1" == "-h" -o "$1" == "--help" ]; then
    cat <<USAGE
usage: gh_unmaster
       Migrates git repos in the current directory from `master` to `main`

       WARNING: This script has NOT been substantially hardened!

       -h, --help    Print this message and exit
USAGE
    exit 0
fi

for REPO_PATH in */; do
  REPO_NAME=$(basename "$REPO_PATH")

  # Check if it's a git repo
  if [ ! -d "$REPO_PATH/.git" ]; then
    echo "Skipping $REPO_NAME: not a git repository"
    continue
  fi

  # Check if master branch exists
  if ! git -C "$REPO_PATH" show-ref --verify --quiet refs/heads/master; then
    echo "Skipping $REPO_NAME: no master branch"
    continue
  fi

  echo "Updating $(basename $REPO_PATH)..."
  git -C "$REPO_PATH" fetch origin
  $DRY_RUN git -C "$REPO_PATH" checkout main
  $DRY_RUN git -C "$REPO_PATH" branch -d master
  $DRY_RUN git -C "$REPO_PATH" remote set-head origin main

  echo "Done: $(basename $REPO_PATH)"
  sleep 10
done
