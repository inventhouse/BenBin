set -eo pipefail
# set -x  # Uncomment for debugging
DRY_RUN=echo
if [ -n "$DRY_RUN" ]; then
    echo "DRY RUN"
fi

export GIT_SSH_COMMAND="ssh -o ConnectTimeout=15 -o ServerAliveInterval=10 -o ServerAliveCountMax=3"

retry() {
  local delay=5
  for attempt in 1 2 3 4 5; do
    if timeout 60 "$@"; then
      return 0
    fi
    echo "  Command failed (attempt $attempt), retrying in ${delay}s..."
    sleep $delay
    delay=$((delay * 2))
  done
  echo "  ERROR: command failed after 5 attempts, skipping"
  return 1
}

if [ "$1" == "-h" -o "$1" == "--help" ]; then
    cat <<USAGE
usage: gh_unmaster
       Migrates git repos in the current directory from `master` to `main`

       WARNING: This script has NOT been substantially hardened!

       -h, --help    Print this message and exit
USAGE
    exit 0
fi

DONE_FILE="${DONE_FILE:-${TMPDIR}/$(basename $0).done}"
if [ -f "$DONE_FILE" ]; then
  echo "Resuming with $DONE_FILE"
else
  echo "Creating $DONE_FILE to track progress"
  touch "$DONE_FILE"
fi

for REPO_PATH in */; do
  REPO_NAME=$(basename "$REPO_PATH")

  # Check if it's a git repo
  if [ ! -d "$REPO_PATH/.git" ]; then
    echo "Skipping $REPO_NAME: not a git repository"
    continue
  fi

  # Check if master branch exists
  if ! git -C "$REPO_PATH" show-ref --verify --quiet refs/heads/master; then
    echo "Skipping $REPO_NAME: no master branch"
    continue
  fi

  # Check if already done
  if grep -qxF "$REPO_PATH" "$DONE_FILE"; then
    echo "Skipping $REPO_NAME: already done"
    continue
  fi

  echo "Updating $(basename $REPO_PATH)..."
  retry git -C "$REPO_PATH" fetch origin || continue
  $DRY_RUN git -C "$REPO_PATH" checkout main
  $DRY_RUN git -C "$REPO_PATH" branch -d master
  $DRY_RUN git -C "$REPO_PATH" remote set-head origin main

  echo "$REPO_PATH" >> "$DONE_FILE"
  echo "Done: $(basename $REPO_PATH)"
done
