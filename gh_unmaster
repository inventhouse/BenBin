set -eo pipefail
# set -x  # Uncomment for debugging
DRY_RUN=echo
if [ -n "$DRY_RUN" ]; then
    echo "DRY RUN"
fi

if [ "$1" == "-h" -o "$1" == "--help" ]; then
    cat <<USAGE
usage: gh_unmaster
       Migrates git repos in the current directory from `master` to `main`

       WARNING: This script has NOT been substantially hardened!

       -h, --help    Print this message and exit
USAGE
    exit 0
fi

GITHUB_USER=$(gh api user --jq .login)

for REPO_PATH in */; do
  REPO_NAME=$(basename "$REPO_PATH")

  # Check if it's a git repo
  if [ ! -d "$REPO_PATH/.git" ]; then
    echo "Skipping $REPO_NAME: not a git repository"
    continue
  fi

  # Check if master branch exists
  if ! git -C "$REPO_PATH" show-ref --verify --quiet refs/heads/master; then
    echo "Skipping $REPO_NAME: no master branch"
    continue
  fi

  echo "Renaming master to main in $REPO_NAME..."

  # Rename the local branch
  $DRY_RUN git -C "$REPO_PATH" branch -m master main

  # Push the new main branch and set upstream
  $DRY_RUN git -C "$REPO_PATH" push origin main

  # Update the default branch on GitHub
  $DRY_RUN gh repo edit "$GITHUB_USER/$REPO_NAME" --default-branch main

  # Delete the old master branch on the remote
  $DRY_RUN git -C "$REPO_PATH" push origin --delete master

  echo "Done: $REPO_NAME"
  sleep 2
done
